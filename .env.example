OLLAMA_MODEL=gpt-oss:120b-cloud
# Optional override. The app defaults to gpt-oss:120b-cloud if you leave this alone.
# Required for Netlify and other deployed production environments.
# When set, VibeJudge calls Ollama Cloud at https://ollama.com directly.
# If omitted, localhost is only used as an optional fallback during local `npm run dev`.
# OLLAMA_API_KEY=your_ollama_cloud_api_key_here
